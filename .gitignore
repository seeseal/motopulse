# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android sensitive & build output
android/local.properties
android/.gradle/
android/key.properties
android/build/

# iOS
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/flutter_export_environment.sh
ios/Runner/GeneratedPluginRegistrant.*
ios/Pods/

# Flutter plugins list (regenerated each run)
.flutter-plugins

# Env & secrets — never commit these
*.env
.env.*
secrets.json
service_account_key.json

# macOS
.DS_Store
**/.DS_Store

# Temp files & local build scripts
commitmsg.txt
commitmsg_*.txt
upload_apk.ps1
run_build.js
build_v*.bat
release_v*.ps1

# Build & test logs
build_log.txt
build_v*_log.txt
pub_get_log.txt
pub_get_err.txt
*test.txt
*test2.txt
envtest.txt
wheretest.txt
